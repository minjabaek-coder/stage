# STAGE 환경 변수 샘플
# 이 파일을 `.env.local`로 복사해 값을 채우세요.

# PostgreSQL 연결 문자열 (Supabase Transaction Pooler, port 6543, ap-northeast-2)
DATABASE_URL=

# Supabase 프로젝트
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용 (클라이언트 노출 금지)

# Google Gemini — AI 마에스트로 챗 + RAG 임베딩 (서버 전용)
GEMINI_API_KEY=

# ── 선택 (미설정 시 코드 기본값 사용) ────────────────────────
GEMINI_MODEL=                        # 기본: gemini-3.1-flash-lite
EMBEDDING_MODEL=                     # 기본: gemini-embedding-001 (1024dim)
NEXT_PUBLIC_SITE_URL=                # 기본: https://www.bon-stage.com (canonical/OG)

# 참고: VERCEL_ENV / NODE_ENV는 플랫폼이 자동 주입 — 여기에 넣지 않습니다.
