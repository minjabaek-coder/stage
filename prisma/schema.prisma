generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MagazineStatus {
  draft
  published
  unpublished
}

enum MagazineContentType {
  image
  web
}

model Magazine {
  id            String              @id @default(cuid())
  issueNumber   Int                 @unique
  title         String
  description   String?
  status        MagazineStatus      @default(draft)
  contentType   MagazineContentType @default(image)
  coverImageUrl String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  viewCount     Int                 @default(0)
  publishedAt   DateTime?
  pages         MagazinePage[]
  tocEntries    MagazineTocEntry[]
  articles      MagazineArticle[]

  @@index([status, publishedAt(sort: Desc)])
}

model MagazinePage {
  id         String   @id @default(cuid())
  magazineId String
  pageNumber Int
  imageUrl   String
  sortOrder  Int
  createdAt  DateTime @default(now())
  magazine   Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@unique([magazineId, sortOrder])
  @@index([magazineId, sortOrder])
}

model MagazineTocEntry {
  id         String   @id @default(cuid())
  magazineId String
  title      String
  pageNumber Int
  sortOrder  Int
  createdAt  DateTime @default(now())
  magazine   Magazine @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@index([magazineId, sortOrder])
}

model MagazineArticle {
  id           String         @id @default(cuid())
  magazineId   String
  title        String
  slug         String
  content      String         @default("") @db.Text
  author       String         @default("")
  section      String         @default("")
  thumbnailUrl String?
  sortOrder    Int
  isCoverStory Boolean        @default(false)
  status       BlogPostStatus @default(draft)
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  magazine     Magazine       @relation(fields: [magazineId], references: [id], onDelete: Cascade)

  @@unique([magazineId, slug])
  @@index([magazineId, sortOrder])
}

enum BlogPostStatus {
  draft
  published
}

enum EmbeddingStatus {
  none
  processing
  completed
  failed
}

model BlogPost {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  content         String          @default("") @db.Text
  thumbnailUrl    String?
  author          String          @default("")
  tags            String[]
  viewCount       Int             @default(0)
  status          BlogPostStatus  @default(draft)
  embeddingStatus EmbeddingStatus @default(none)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  chunks          BlogPostChunk[]

  @@index([status, publishedAt(sort: Desc)])
}

/// RAG 임베딩 청크 (pgvector). 실제 테이블은 raw SQL 마이그레이션으로 생성됨.
/// 임베딩 검색/삽입은 src/lib/rag.ts에서 raw SQL로 처리(embedding은 Unsupported).
/// 주의: HNSW 벡터 인덱스(BlogPostChunk_embedding_idx)는 Prisma로 표현 불가 →
/// 스키마엔 없지만 DB/마이그레이션엔 존재하므로 수기 마이그레이션 시 건드리지 말 것.
model BlogPostChunk {
  id         String                       @id @default(dbgenerated("gen_random_uuid()::text"))
  blogPostId String
  chunkIndex Int
  title      String
  content    String                       @db.Text
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime                     @default(now())
  blogPost   BlogPost                     @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([blogPostId])
}

// 단독 기사 (매거진과 별개의 독립 아티클). 프리미엄 게이팅(isPremium + 등급).
model Article {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  excerpt      String?
  content      String         @default("") @db.Text
  author       String         @default("")
  category     String         @default("")
  tags         String[]
  thumbnailUrl String?
  isFeatured   Boolean        @default(false)
  isPremium    Boolean        @default(false)
  aiIndexable  Boolean        @default(true)
  viewCount    Int            @default(0)
  status       BlogPostStatus @default(draft)
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([category])
}

// 뉴스레터 구독자 (기존 운영 테이블을 채택해 baseline)
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  source    String   @default("home")
  createdAt DateTime @default(now())

  @@index([isActive])
}

enum UserTier {
  guest
  member
  pro
}

// 회원 (Supabase Auth와 authId로 연결)
model User {
  id              String          @id @default(cuid())
  authId          String?         @unique
  email           String          @unique
  name            String          @default("")
  avatarUrl       String?
  snsProvider     String?
  tier            UserTier        @default(member)
  interests       String[]
  proExpiresAt    DateTime?
  newsletterOptIn Boolean         @default(false)
  eventAlertOptIn Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  aiInteractions  AiInteraction[]
}

// AI 마에스트로 상호작용 로그 (회원/세션 단위)
model AiInteraction {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  question    String
  answer      String
  magazineId  String?
  articleId   String?
  sourceCount Int      @default(0)
  provider    String   @default("gemini")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId])
}

model ApiCallLog {
  id            String   @id @default(cuid())
  model         String
  userMessage   String   @db.Text
  response      String   @db.Text
  sourceCount   Int      @default(0)
  tokensIn      Int      @default(0)
  tokensOut     Int      @default(0)
  durationMs    Int      @default(0)
  status        String   @default("success")
  error         String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}
